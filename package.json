{
  "name": "browser-mcp",
  "version": "1.0.0",
  "description": "Stealth-first Chrome browser MCP runtime",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "acceptance:complex-layout": "node scripts/verify-complex-layout.mjs",
    "acceptance:boss-mock": "node scripts/verify-boss-recruiting-task.mjs",
    "acceptance:detectable-surface": "node scripts/verify-detectable-surface.mjs",
    "acceptance:native-host-allowlist": "node scripts/verify-native-host-allowlist.mjs",
    "acceptance:mcp-serialization": "node scripts/verify-mcp-serialization.mjs",
    "acceptance:smoke": "node scripts/acceptance-smoke.mjs",
    "mock:boss-recruiting": "node scripts/boss-recruiting-task-fixture.mjs",
    "health:runtime": "node scripts/check-runtime-health.mjs",
    "setup:auto": "node scripts/setup-auto.mjs",
    "mcp:start": "node mcp/server.mjs",
    "native-host:start": "node native-host/host.mjs --debug-standalone",
    "native-host:stdio": "node native-host/host.mjs",
    "native-host:install": "node scripts/install-native-host.mjs",
    "codex:mcp:install": "node scripts/install-codex-mcp.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.7",
    "rollup": "^4.60.1",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "vite-plugin-static-copy": "^4.0.0"
  }
}
